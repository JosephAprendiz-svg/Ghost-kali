# trio_parse_args → parsea todos los flags de línea de comandos.
trio_parse_args() {
    local a
    while [[ $# -gt 0 ]]; do
        a=$1
        case $a in
            -h | --help)
                trio_show_help
                exit 0
                ;;
            -v | --version)
                trio_show_version
                exit 0
                ;;
            --dry-run) GHOST_DRY_RUN=1 ;;
            --no-color)
                GHOST_BANNER_NO_COLOR=1
                GHOST_NO_COLOR=1
                ;;
            --no-fade) GHOST_BANNER_NO_FADE=1 ;;
            --banner-mode)
                shift
                GHOST_BANNER_MODE=${1:-full}
                ;;
            --banner-mode=*) GHOST_BANNER_MODE=${a#*=} ;;
            --check) GHOST_ACTION=check ;;
            --dashboard) GHOST_ACTION=dashboard ;;
            --connect) GHOST_ACTION=connect ;;
            --disconnect) GHOST_ACTION=disconnect ;;
            --status) GHOST_ACTION=status ;;
            *)
                printf 'Opción desconocida: %s\n\n' "$a" >&2
                trio_show_help
                exit 2
                ;;
        esac
        shift
    done

    # Validamos el modo de banner; si no es válido, caemos a full.
    case ${GHOST_BANNER_MODE} in
        full | minimal | classic | retro) ;;
        *) GHOST_BANNER_MODE=full ;;
    esac

    export GHOST_DRY_RUN GHOST_BANNER_MODE
    export GHOST_BANNER_NO_COLOR GHOST_BANNER_NO_FADE GHOST_NO_COLOR 2>/dev/null || true
}

