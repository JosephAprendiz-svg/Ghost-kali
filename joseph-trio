# _trio_resolve_base_dir → detecta la raíz del proyecto (resolviendo symlinks).
# POR QUÉ resolver symlinks: el script puede invocarse a través de un enlace en
# /usr/local/bin; necesitamos la ruta real para encontrar lib/.
_trio_resolve_base_dir() {
    local src=${BASH_SOURCE[0]} dir
    while [[ -L $src ]]; do
        dir=$(cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)
        src=$(readlink "$src")
        [[ $src != /* ]] && src="${dir}/${src}"
    done
    GHOST_BASE_DIR=$(cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)
    GHOST_LIB_DIR="${GHOST_BASE_DIR}/lib"
}

# _trio_die MENSAJE [CÓDIGO] → error fatal limpio (usa log si está disponible).
_trio_die() {
    local msg=$1 code=${2:-1}
    if declare -F log_error >/dev/null 2>&1; then
        log_error "$msg"
    else
        printf 'ERROR: %s\n' "$msg" >&2
    fi
    exit "$code"
}

# _trio_confirm MENSAJE → pregunta sí/no (devuelve 0 si sí). En modo no
# interactivo (confirmación previa o automatización) devuelve 0 sin preguntar.
_trio_confirm() {
    [[ ${GHOST_NON_INTERACTIVE:-0} == 1 ]] && return 0
    printf '%s%s%s [s/N]: ' "${C_WARNING:-}" "$1" "${C_RESET:-}"
    local ans
    read -r ans || return 1
    [[ $ans =~ ^[sSyY]$ ]]
}

# _trio_press_enter → pausa hasta ENTER (no pausa en modo no interactivo).
_trio_press_enter() {
    [[ ${GHOST_NON_INTERACTIVE:-0} == 1 ]] && return 0
    printf '\n%sPulsa ENTER para continuar…%s' "${C_MUTED:-}" "${C_RESET:-}"
    read -r _ || true
}

# _trio_clear → limpia la pantalla de forma portable (solo si es una terminal).
_trio_clear() {
    if declare -F dashboard_clear_screen >/dev/null 2>&1; then
        dashboard_clear_screen
        return 0
    fi
    [[ -t 1 ]] || return 0
    if command -v tput >/dev/null 2>&1 && tput clear 2>/dev/null; then
        return 0
    fi
    printf '\033[2J\033[H'
}

# _trio_cleanup → restaura el terminal al salir (cursor visible).
_trio_cleanup() {
    command -v tput >/dev/null 2>&1 && tput cnorm 2>/dev/null || true
}

# _trio_on_int → manejador de Ctrl+C: avisa sin romper bruscamente.
_trio_on_int() {
    printf '\n'
    if declare -F log_warn >/dev/null 2>&1; then
        log_warn "Interrupción recibida (Ctrl+C)."
    fi
}

