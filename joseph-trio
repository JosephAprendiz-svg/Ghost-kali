# trio_load_libs → carga todas las librerías de lib/ en el orden de dependencias.
trio_load_libs() {
    local lib path
    local -a libs=(colors logger validators torctl vpnctl netutils dashboard banner)
    local -a missing=()
    for lib in "${libs[@]}"; do
        path="${GHOST_LIB_DIR}/${lib}.sh"
        if [[ -f $path ]]; then
            # shellcheck source=/dev/null
            source "$path"
        else
            missing+=("lib/${lib}.sh")
        fi
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        _trio_die "Faltan librerías: ${missing[*]}. Ejecuta ./install.sh o clona el repositorio completo." 2
    fi

    # Aplica preferencias de presentación ya parseadas.
    if [[ ${GHOST_BANNER_NO_COLOR:-0} == 1 ]] && declare -F set_color_mode >/dev/null 2>&1; then
        set_color_mode none
    elif declare -F apply_theme >/dev/null 2>&1; then
        apply_theme "${GHOST_THEME:-ghost}" >/dev/null 2>&1 || true
    fi
}

