# trio_require_root → exige root salvo en --dry-run (la simulación no cambia nada).
trio_require_root() {
    local uid=${EUID:-$(id -u)}
    if [[ $uid -eq 0 ]]; then
        return 0
    fi
    if [[ ${GHOST_DRY_RUN:-0} == 1 ]]; then
        log_warn "No eres root, pero en --dry-run no se harán cambios. Continúo en simulación."
        return 0
    fi
    log_error "Se requieren privilegios de root para gestionar red/túnel."
    log_error "Ejecuta: sudo ./joseph-trio"
    return 1
}

# trio_check_health → verificación de salud del toolkit (vía validators.sh).
trio_check_health() {
