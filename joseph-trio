# trio_connect_all → conecta Mullvad → Tor → Proxychains (opción 1 / --connect).
trio_connect_all() {
    log_section "Conectar todo: Mullvad → Tor → Proxychains"
    log_warn "Esto cambiará el enrutamiento de tu tráfico para anonimizarlo."
    _trio_confirm "¿Continuar con la conexión completa?" || {
        log_warn "Conexión cancelada."
        return 1
    }

    # Ya confirmaste; ejecutamos los pasos sin más prompts.
    local prev_ni=${GHOST_NON_INTERACTIVE:-0}
    GHOST_NON_INTERACTIVE=1

    log_section "1/3 · Mullvad VPN"
    if declare -F vpn_connect >/dev/null 2>&1; then vpn_connect; else log_warn "vpnctl no disponible."; fi

    log_section "2/3 · Tor"
    _trio_tor_start

    log_section "3/3 · Proxychains"
    _trio_proxychains_enable

    GHOST_NON_INTERACTIVE=$prev_ni
    log_ok "Secuencia de conexión completada. Verifica con la opción 3 (estado)."
}

# trio_disconnect_all → desconecta Proxychains → Tor → Mullvad (opción 2).
trio_disconnect_all() {
    log_section "Desconectar todo y limpiar"
    _trio_confirm "¿Desconectar Proxychains, Tor y Mullvad?" || {
        log_warn "Operación cancelada."
        return 1
    }

    local prev_ni=${GHOST_NON_INTERACTIVE:-0}
    GHOST_NON_INTERACTIVE=1

    log_section "1/3 · Proxychains"
    _trio_proxychains_disable

    log_section "2/3 · Tor"
    _trio_tor_stop

    log_section "3/3 · Mullvad VPN"
    if declare -F vpn_disconnect >/dev/null 2>&1; then vpn_disconnect; else log_warn "vpnctl no disponible."; fi

    GHOST_NON_INTERACTIVE=$prev_ni
    log_ok "Desconexión completada."
}

