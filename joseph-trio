# _trio_menu_vpn → submenú de gestión de Mullvad (opción 8).
_trio_menu_vpn() {
    local c
    while true; do
        printf '\n  %s[a]%s Conectar   %s[b]%s Desconectar   %s[c]%s Cambiar relay   %s[0]%s Volver\n  > ' \
            "${C_ACCENT:-}" "${C_RESET:-}" "${C_ACCENT:-}" "${C_RESET:-}" \
            "${C_ACCENT:-}" "${C_RESET:-}" "${C_ACCENT:-}" "${C_RESET:-}"
        read -r c || return 0
        case ${c,,} in
            a) declare -F vpn_connect >/dev/null 2>&1 && vpn_connect ;;
            b) declare -F vpn_disconnect >/dev/null 2>&1 && vpn_disconnect ;;
            c) _trio_vpn_change_relay ;;
            0 | q) return 0 ;;
            *) log_warn "Opción inválida." ;;
        esac
    done
}

# _trio_vpn_change_relay → pide país/ciudad y cambia el relay (vía vpnctl).
_trio_vpn_change_relay() {
    printf 'País (código de 2 letras, p. ej. se): '
    local cc city
    read -r cc || return 1
    printf 'Ciudad (opcional, ENTER para omitir): '
    read -r city || true
    local -a args=("$cc")
    [[ -n $city ]] && args+=("$city")
    declare -F vpn_set_relay >/dev/null 2>&1 && vpn_set_relay "${args[@]}"
}

# _trio_menu_tor → submenú de gestión de Tor (opción 9).
_trio_menu_tor() {
    local c
    while true; do
        printf '\n  %s[a]%s Iniciar   %s[b]%s Detener   %s[c]%s Nuevo circuito   %s[d]%s Ver circuitos   %s[0]%s Volver\n  > ' \
            "${C_ACCENT:-}" "${C_RESET:-}" "${C_ACCENT:-}" "${C_RESET:-}" \
            "${C_ACCENT:-}" "${C_RESET:-}" "${C_ACCENT:-}" "${C_RESET:-}" \
            "${C_ACCENT:-}" "${C_RESET:-}"
        read -r c || return 0
        case ${c,,} in
            a) _trio_tor_start ;;
            b) _trio_tor_stop ;;
            c) declare -F tor_newnym >/dev/null 2>&1 && tor_newnym ;;
            d) declare -F tor_get_circuits >/dev/null 2>&1 && tor_get_circuits ;;
            0 | q) return 0 ;;
            *) log_warn "Opción inválida." ;;
        esac
    done
}

# _trio_menu_proxychains → submenú de gestión de Proxychains (opción 10).
_trio_menu_proxychains() {
    local c
    while true; do
        printf '\n  %s[a]%s Verificar config   %s[b]%s Cambiar cadena   %s[0]%s Volver\n  > ' \
            "${C_ACCENT:-}" "${C_RESET:-}" "${C_ACCENT:-}" "${C_RESET:-}" \
            "${C_ACCENT:-}" "${C_RESET:-}"
        read -r c || return 0
        case ${c,,} in
            a) _trio_proxychains_check ;;
            b) _trio_proxychains_change_chain ;;
            0 | q) return 0 ;;
            *) log_warn "Opción inválida." ;;
        esac
    done
}

# ──────────────────────────────────────────────────────────────────────────────
#  MENÚ PRINCIPAL
# ──────────────────────────────────────────────────────────────────────────────

# trio_show_menu → dibuja el menú principal de 12 opciones.
trio_show_menu() {
    local p=${C_PRIMARY:-} a=${C_ACCENT:-} m=${C_MUTED:-} r=${C_RESET:-} modo
    if [[ ${GHOST_DRY_RUN:-0} == 1 ]]; then modo="SIMULACIÓN (--dry-run)"; else modo="real"; fi

    printf '\n%s  Menú principal%s   %s(modo: %s)%s\n' "$p" "$r" "$m" "$modo" "$r"
    printf '%s  ──────────────────────────────────────────────────────────%s\n' "$m" "$r"
    printf '   %s[1]%s  Conectar todo (Mullvad → Tor → Proxychains)\n' "$a" "$r"
    printf '   %s[2]%s  Desconectar todo y limpiar rutas\n' "$a" "$r"
    printf '   %s[3]%s  Estado del trio (VPN / Tor / Proxychains)\n' "$a" "$r"
    printf '   %s[4]%s  Dashboard en vivo\n' "$a" "$r"
    printf '   %s[5]%s  Verificar IP pública y geolocalización\n' "$a" "$r"
    printf '   %s[6]%s  Test de fugas DNS\n' "$a" "$r"
    printf '   %s[7]%s  Test de fugas WebRTC (guía)\n' "$a" "$r"
    printf '   %s[8]%s  Gestionar Mullvad VPN (conectar / desconectar / relay)\n' "$a" "$r"
    printf '   %s[9]%s  Gestionar Tor (iniciar / nuevo circuito / ver circuitos)\n' "$a" "$r"
    printf '  %s[10]%s  Gestionar Proxychains (verificar / cambiar cadena)\n' "$a" "$r"
    printf '  %s[11]%s  Hardening rápido (IPv6, resolutores DNS, MAC)\n' "$a" "$r"
    printf '  %s[12]%s  Acerca de / ayuda / disclaimer\n' "$a" "$r"
    printf '\n   %s[0]%s  Salir\n' "$a" "$r"
}

# trio_handle_choice N → ejecuta la opción del menú. Devuelve 10 para salir.
trio_handle_choice() {
    case $1 in
        1) trio_connect_all ;;
        2) trio_disconnect_all ;;
        3) trio_status ;;
        4) trio_dashboard ;;
        5) declare -F net_get_public_ip >/dev/null 2>&1 && net_get_public_ip ;;
        6) declare -F net_dns_leak_test >/dev/null 2>&1 && net_dns_leak_test ;;
        7) _trio_webrtc_guide ;;
        8) _trio_menu_vpn ;;
        9) _trio_menu_tor ;;
        10) _trio_menu_proxychains ;;
        11) _trio_hardening ;;
        12) trio_about ;;
        0) return 10 ;;
        *) log_warn "Opción inválida: $1" ;;
    esac
    return 0
}

# trio_run_with_banner FUNC → muestra el banner y luego ejecuta la función dada.
trio_run_with_banner() {
    local fn=$1
    declare -F banner_show >/dev/null 2>&1 && banner_show "${GHOST_BANNER_MODE:-full}"
    "$fn"
}

# trio_menu_loop → bucle del menú interactivo.
trio_menu_loop() {
    local choice rc
    while true; do
        _trio_clear
        declare -F banner_show >/dev/null 2>&1 && banner_show minimal --no-fade
        trio_show_menu
        printf '\n  %sSelecciona una opción [0-12]:%s ' "${C_PRIMARY:-}" "${C_RESET:-}"

        read -r choice
        rc=$?
        if [[ $rc -gt 128 ]]; then
            # Señal (p. ej. Ctrl+C): volvemos a dibujar el menú.
            printf '\n'
            continue
        fi
        if [[ $rc -ne 0 ]]; then
            # EOF (Ctrl+D): salimos.
            printf '\n'
            break
        fi
        [[ -z $choice ]] && continue

        trio_handle_choice "$choice"
        [[ $? -eq 10 ]] && break
        _trio_press_enter
    done
    log_info "Saliendo de ${GHOST_NAME}. Mantén tu privacidad. 🛡"
}

# ──────────────────────────────────────────────────────────────────────────────
#  PUNTO DE ENTRADA
# ──────────────────────────────────────────────────────────────────────────────
main() {
    _trio_resolve_base_dir
    trio_parse_args "$@"
    trio_load_libs

    # Manejo de señales y restauración del terminal.
    trap _trio_cleanup EXIT
    trap _trio_on_int INT

    # Acciones directas por flag (no entran al menú).
    case ${GHOST_ACTION:-} in
        check)
            trio_check_health
            exit $?
            ;;
        status)
            trio_require_root || exit 1
            trio_status
            exit 0
            ;;
        dashboard)
            trio_require_root || exit 1
            trio_run_with_banner trio_dashboard
            exit 0
            ;;
        connect)
            trio_require_root || exit 1
            trio_run_with_banner trio_connect_all
            exit 0
            ;;
        disconnect)
            trio_require_root || exit 1
            trio_run_with_banner trio_disconnect_all
            exit 0
            ;;
    esac

    # Sin acción directa: menú interactivo (requiere root salvo en --dry-run).
    trio_require_root || exit 1
    trio_menu_loop
}

main "$@"

