}

# ──────────────────────────────────────────────────────────────────────────────
#  CONTROL DE TOR / PROXYCHAINS (helpers del orquestador)
#  NOTA: torctl.sh gestiona un Tor YA en marcha (vía ControlPort). Arrancar o
#  detener el servicio es una acción de systemd puntual, explícita y confirmada
#  por el usuario (nunca indiscriminada), siempre con soporte de --dry-run.
# ──────────────────────────────────────────────────────────────────────────────

# _trio_tor_start → inicia el servicio Tor (systemctl), respetando --dry-run.
_trio_tor_start() {
    if [[ ${GHOST_DRY_RUN:-0} == 1 ]]; then
        log_info "[dry-run] Ejecutaría: systemctl start tor"
        return 0
    fi
    if ! command -v systemctl >/dev/null 2>&1; then
        log_error "systemctl no está disponible; inicia Tor manualmente."
        return 1
    fi
    log_info "Iniciando el servicio Tor…"
    if systemctl start tor 2>/dev/null; then
        log_ok "Servicio Tor iniciado."
        return 0
    fi
    log_error "No se pudo iniciar Tor (¿está instalado? ¿tienes permisos?)."
    return 1
}

# _trio_tor_stop → detiene el servicio Tor (acción explícita y confirmada).
_trio_tor_stop() {
    if [[ ${GHOST_DRY_RUN:-0} == 1 ]]; then
        log_info "[dry-run] Ejecutaría: systemctl stop tor"
        return 0
    fi
    _trio_confirm "¿Detener el servicio Tor?" || return 1
    if ! command -v systemctl >/dev/null 2>&1; then
        log_error "systemctl no está disponible; detén Tor manualmente."
        return 1
    fi
    if systemctl stop tor 2>/dev/null; then
        log_ok "Servicio Tor detenido."
        return 0
    fi
    log_error "No se pudo detener Tor."
    return 1
}

# _trio_proxychains_conf → imprime la ruta del proxychains.conf legible, si existe.
_trio_proxychains_conf() {
    local c
    for c in /etc/proxychains4.conf /etc/proxychains.conf; do
        [[ -r $c ]] && {
            printf '%s' "$c"
            return 0
        }
    done
    return 1
}

# _trio_proxychains_check → verifica la configuración de proxychains (solo lectura).
_trio_proxychains_check() {
    local conf
    if ! conf=$(_trio_proxychains_conf); then
        log_warn "No se encontró un proxychains.conf legible."
        return 1
    fi
    log_section "Proxychains"
    local mode
    mode=$(grep -E '^(dynamic_chain|strict_chain|random_chain)' "$conf" | head -1)
    log_table "Config" "$conf" "Modo de cadena" "${mode:-?}"
    if grep -Eq "^[[:space:]]*socks[45][[:space:]]+127\.0\.0\.1[[:space:]]+9050" "$conf"; then
        log_ok "Proxychains enruta por el SOCKS de Tor (127.0.0.1:9050)."
    else
        log_warn "Proxychains NO apunta a 127.0.0.1:9050 (SOCKS de Tor)."
    fi
    log_info "Uso: antepón «proxychains4» a tu comando, p. ej.: proxychains4 firefox"
}

# _trio_proxychains_enable → «activa» proxychains (en realidad: verifica y guía).
# POR QUÉ no es un servicio: proxychains se aplica por comando, no a nivel de
# sistema. Ser honestos evita dar una falsa sensación de protección global.
_trio_proxychains_enable() {
    if [[ ${GHOST_DRY_RUN:-0} == 1 ]]; then
        log_info "[dry-run] Verificaría proxychains.conf y mostraría cómo usarlo."
        return 0
    fi
    _trio_proxychains_check
    log_info "Proxychains no es un servicio: queda listo para usarse con «proxychains4 <app>»."
}

# _trio_proxychains_disable → «desactiva» proxychains (no hay servicio que parar).
_trio_proxychains_disable() {
    if [[ ${GHOST_DRY_RUN:-0} == 1 ]]; then
        log_info "[dry-run] proxychains se aplica por comando; no hay servicio que detener."
        return 0
    fi
    log_info "Proxychains deja de usarse simplemente al no anteponer «proxychains4»."
    log_ok "Nada que desactivar a nivel de sistema."
}

# _trio_proxychains_change_chain → cambia el modo de cadena (con confirmación y
# copia de seguridad). Modifica un archivo del sistema SOLO con consentimiento.
_trio_proxychains_change_chain() {
    local conf
    if ! conf=$(_trio_proxychains_conf); then
        log_error "No se encontró proxychains.conf."
        return 1
    fi
    log_info "Modos: dynamic_chain (recomendado), strict_chain, random_chain."
    printf 'Nuevo modo [dynamic/strict/random]: '
    local m directive
    read -r m || return 1
    case ${m,,} in
        dynamic) directive=dynamic_chain ;;
        strict) directive=strict_chain ;;
        random) directive=random_chain ;;
        *)
            log_error "Modo inválido."
            return 1
            ;;
    esac

    if [[ ${GHOST_DRY_RUN:-0} == 1 ]]; then
        log_info "[dry-run] Activaría «${directive}» en ${conf} (creando backup)."
        return 0
    fi
    _trio_confirm "Esto modificará ${conf}. ¿Continuar?" || return 1
    if [[ ! -w $conf ]]; then
        log_error "Sin permiso de escritura en ${conf} (ejecuta como root)."
        return 1
    fi

    cp -f "$conf" "${conf}.ghostbak.$(date +%s)" 2>/dev/null &&
        log_info "Backup creado de ${conf}."
    # Comentamos los tres modos y dejamos activo solo el elegido.
    sed -i -E 's/^[[:space:]]*#?[[:space:]]*(dynamic_chain|strict_chain|random_chain)/#\1/' "$conf"
    sed -i -E "s/^#?[[:space:]]*${directive}\b/${directive}/" "$conf"
    log_ok "Modo de cadena cambiado a ${directive}."
}

