# _trio_hardening → hardening rápido (opción 11): IPv6, resolutores DNS y MAC.
_trio_hardening() {
    log_section "Hardening rápido"

    # IPv6 (cambio de runtime, NO persistente, con confirmación y --dry-run).
    local v6
    v6=$(sysctl -n net.ipv6.conf.all.disable_ipv6 2>/dev/null)
    log_info "IPv6 deshabilitado actualmente: ${v6:-desconocido}"
    if [[ ${v6:-0} != 1 ]]; then
        if [[ ${GHOST_DRY_RUN:-0} == 1 ]]; then
            log_info "[dry-run] Ejecutaría: sysctl -w net.ipv6.conf.all.disable_ipv6=1 (runtime)"
        elif _trio_confirm "¿Desactivar IPv6 en runtime para evitar fugas? (no persistente)"; then
            if sysctl -w net.ipv6.conf.all.disable_ipv6=1 >/dev/null 2>&1 &&
                sysctl -w net.ipv6.conf.default.disable_ipv6=1 >/dev/null 2>&1; then
                log_ok "IPv6 desactivado en runtime."
                log_info "Para hacerlo persistente, añádelo tú a /etc/sysctl.d/ (acción manual)."
            else
                log_error "No se pudo desactivar IPv6 (¿tienes permisos de root?)."
            fi
        fi
    else
        log_ok "IPv6 ya está deshabilitado."
    fi

    # Resolutores DNS.
    declare -F net_dns_leak_test >/dev/null 2>&1 && net_dns_leak_test

    # Aleatorización de MAC: solo verificación (cambiarla es una acción sensible).
    log_section "Aleatorización de MAC (verificación)"
    if command -v macchanger >/dev/null 2>&1; then
        log_ok "macchanger está instalado; puedes aleatorizar tu MAC manualmente."
    else
        log_warn "macchanger no está instalado; sin él no puedes aleatorizar la MAC fácilmente."
    fi
    log_info "Este toolkit solo VERIFICA la MAC; no la cambia automáticamente."
}

